<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Holy Tuna - The Ultimate Musician Hub</title>
    <link rel="stylesheet" href="/styles/index.css">
    <link rel="stylesheet" href="/styles/site.css">
</head>
<body>

  <%- include('partials/header') %>

  <section class="Hero-section">
    <div class="hero-overlay"></div>
    <div class="waw">
      <div class="video-container">
        <video width="100%" height="auto" controls>
          <source src="/styles/videos/rap-battle---monika-vs-benjamin-netanyahu.mp4" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
      <div class="hero-text-side">
        <h1>Your story starts here</h1>
        <p class="hero-subtitle">The ultimate competitive tuner, chord library, and social marketplace for musicians.</p>
      </div>
    </div>
  </section>

  <section class="carousel-container">
    <div class="carousel">
      <div class="carousel__track">
        <div class="carousel__slide">
          <div class="textbx" style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/styles/images/360_F_1687528008_b3UEvXStsFivolLMOSeuTrPM3QC6y6Qm.jpg');">
            <h3>What are we?</h3>
            <p>HolyTuna is an advanced cross-platform suite designed to outperform legacy tuners with real-time spectrum frequency analysis.</p>
          </div>
        </div>
        <div class="carousel__slide">
          <div class="textbx" style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/styles/images/the-guitar-store.jpg');">
            <h3>What we offer</h3>
            <p>Access flawless precision tuners, interactive smart transposing chord charts, and global backing tracks right in your browser.</p>
          </div>
        </div>
        <div class="carousel__slide">
          <div class="textbx" style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/styles/images/photo-1605020420620-20c943cc4669.avif');">
            <h3>Why choose us?</h3>
            <p>Built by musicians, for musicians. Experience zero delay performance tracking alongside an open marketplace to monetize your craft.</p>
          </div>
        </div>
      </div>
      <button class="carousel__btn carousel__btn--prev"><</button>
      <button class="carousel__btn carousel__btn--next">></button>
      <div class="carousel__nav"></div>
    </div>
  </section>

  <section class="Section-Wrapper services-section">
    <h2 class="section-title services-title">Our Main Services</h2>
    <div class="Main-Menu-Box">
      <a href="/tuner" style="text-decoration: none; color: inherit;">
        <div class="hub-card Tuner-Box">
          <div class="card-icon">🎸</div>
          <h2>Precision Tuner</h2>
          <p>A surgical engine matching your highest performance standards. Supports custom, drop, and alternative structural temperaments.</p>
        </div>
      </a>
      <a href="/chords" style="text-decoration: none; color: inherit;">
        <div class="hub-card Chords-Box">
          <div class="card-icon">🎼</div>
          <h2>Smart Chords</h2>
          <p>Interactive engine optimized for seamless fret placement progression maps. Explore tabs across multiple acoustic variations.</p>
        </div>
      </a>
      <a href="/music" style="text-decoration: none; color: inherit;">
        <div class="hub-card Content-Box">
          <div class="card-icon">🌐</div>
          <h2>Creator Studio</h2>
          <p>Publish your high-fidelity audio tracks, showcase video gear playthroughs, share custom blogs, and sell vintage marketplace instruments.</p>
        </div>
      </a>
    </div>
  </section>

  <section class="Section-Wrapper">
    <h2 class="section-title">Featured Gear From Shop</h2>
    <div class="Featured-shop-items">
      </div>
  </section>

  <section class="Section-Wrapper">
    <h2 class="section-title">Newest Insights & Blogs</h2>
    <div class="Featured-Blogs">
      </div>
  </section>

  <script src="/scripts/index.js"></script>

  <%- include('partials/footer') %>
</body>
</html>