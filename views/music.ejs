<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post Music - HolyTuna</title>
    <link rel="stylesheet" href="/styles/index.css">
    <link rel="stylesheet" href="/styles/site.css">
</head>
<body>

<%- include('partials/header') %>

<main class="content-page">
    <div class="page-header">
        <h1>Creator Studio · Music</h1>
        <p>Share a track with the HolyTuna community.</p>
        <a href="/" class="back-link">&larr; Return to Headquarters</a>
    </div>

    <div class="form-card">
        <h2>Post a Track</h2>

        <% if (error) { %>
            <div class="form-error"><%= error %></div>
        <% } %>

        <form action="/music" method="POST">
            <div class="form-group">
                <label for="title">Track Title</label>
                <input type="text" id="title" name="title" required autofocus placeholder="e.g. Midnight in Drop D">
            </div>

            <div class="form-group">
                <label for="genre">Genre</label>
                <input type="text" id="genre" name="genre" placeholder="e.g. Acoustic, Metal, Lo-fi">
            </div>

            <div class="form-group">
                <label for="link">Link to Your Track</label>
                <input type="url" id="link" name="link" required placeholder="Direct .mp3 link, SoundCloud, etc.">
                <p class="form-hint">Paste a direct audio file link (.mp3/.wav/.ogg) so it can play right on the page, or any streaming link.</p>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" placeholder="Tell people about the track..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Publish Track</button>
        </form>
    </div>

    <hr class="section-divider">

    <h2 class="page-header" style="margin-bottom:1.5rem;">Community Tracks</h2>

    <% if (!tracks || tracks.length === 0) { %>
        <div class="empty-state">No tracks posted yet. Be the first!</div>
    <% } else { %>
        <div class="listing-grid">
            <% tracks.forEach(function(track) { %>
                <div class="listing-card">
                    <h3><%= track.title %></h3>
                    <span class="badge"><%= track.genre %></span>
                    <% if (track.description) { %>
                        <p><%= track.description %></p>
                    <% } %>
                    <% if (/\.(mp3|wav|ogg)(\?.*)?$/i.test(track.link)) { %>
                        <audio controls src="<%= track.link %>"></audio>
                    <% } else { %>
                        <a href="<%= track.link %>" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Listen &#8599;</a>
                    <% } %>
                    <div class="listing-meta">
                        <span>Posted by <strong><%= track.postedBy %></strong></span>
                        <span><%= new Date(track.createdAt).toLocaleDateString() %></span>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</main>


<%- include('partials/footer') %>
</body>
</html>
