<style>
.site-footer {
    position: relative;
    background: #080808;
    color: white;
    padding: 70px 8% 25px;
    margin-top: 5rem;
    overflow: hidden;
    border-top: 1px solid rgba(255,255,255,0.08);
}

.site-footer::before {
    content: "";
    position: absolute;
    width: 500px;
    height: 500px;
    background: #ff7a00;
    opacity: 0.12;
    filter: blur(130px);
    top: -250px;
    left: 50%;
    transform: translateX(-50%);
}

.footer-inner {
    position: relative;
    max-width: 1200px;
    margin: auto;
    display: flex;
    justify-content: space-between;
    gap: 50px;
    flex-wrap: wrap;
}

.footer-brand .logo {
    font-size: 40px;
    font-weight: 900;
    color: white;
    letter-spacing: -1px;
}

.footer-brand .logo span {
    color: #ff7a00;
}

.footer-brand p {
    margin-top: 15px;
    max-width: 330px;
    color: #888;
    line-height: 1.7;
}

.footer-socials {
    display: flex;
    gap: 12px;
    margin-top: 25px;
}

.footer-socials a {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;

    background: #151515;
    color: white;
    text-decoration: none;

    transition: .3s;
}

.footer-socials a:hover {
    background: #ff7a00;
    transform: translateY(-5px);
}

.footer-links {
    display: flex;
    gap: 70px;
}

.footer-col h4 {
    color: white;
    margin-bottom: 15px;
    font-size: 16px;
}

.footer-col a {
    display: block;
    color: #888;
    text-decoration: none;
    margin-bottom: 12px;
    transition: .25s;
}

.footer-col a:hover {
    color: #ff7a00;
    transform: translateX(5px);
}

.footer-line {
    max-width: 1200px;
    height: 1px;
    background: rgba(255,255,255,.1);
    margin: 40px auto 20px;
}

.footer-bottom {
    max-width: 1200px;
    margin: auto;
    display: flex;
    justify-content: space-between;
    color: #666;
    font-size: 14px;
}

@media(max-width:800px){

    .footer-inner {
        flex-direction: column;
    }

    .footer-links {
        gap: 30px;
        flex-wrap: wrap;
    }

    .footer-bottom {
        flex-direction: column;
        gap: 10px;
        text-align: center;
    }
}
</style>
<footer class="site-footer">
    <div class="footer-glow"></div>

    <div class="footer-inner">

        <div class="footer-brand">
            <div class="logo">
                Holy<span>Tuna</span>
            </div>

            <p>
                The ultimate tuner, chord library, and social marketplace
                built for musicians.
            </p>

            <div class="footer-socials">
                <a href="#">𝕏</a>
                <a href="#">◎</a>
                <a href="#">▶</a>
                <a href="#">♪</a>
            </div>
        </div>


        <div class="footer-links">

            <div class="footer-col">
                <h4>Explore</h4>
                <a href="/tuner">Tuner</a>
                <a href="/chords">Chords</a>
                <a href="/shop">Shop</a>
                <a href="/blogs">Blogs</a>
            </div>


            <div class="footer-col">
                <h4>Community</h4>
                <a href="/music">Music</a>
                <a href="/videos">Videos</a>
                <a href="/chat">Chat</a>
            </div>


            <div class="footer-col">
                <h4>Account</h4>
                <a href="/login">Log In</a>
                <a href="/register">Sign Up</a>
                <a href="/account">Profile</a>
            </div>

        </div>

    </div>


    <div class="footer-line"></div>


    <div class="footer-bottom">
        <span>
            © <span id="footer-year"></span> HolyTuna
        </span>

        <span>
            Made for musicians 🎸
        </span>
    </div>

</footer>


<script>
    const yearEl = document.getElementById("footer-year");
    if(yearEl){
        yearEl.textContent = new Date().getFullYear();
    }
</script>