<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post Videos - HolyTuna</title>
    <link rel="stylesheet" href="/styles/index.css">
    <link rel="stylesheet" href="/styles/site.css">
</head>
<body>

<%- include('partials/header') %>

<main class="content-page">
    <div class="page-header">
        <h1>Creator Studio · Videos</h1>
        <p>Share a gear demo, playthrough, or performance with the community.</p>
        <a href="/" class="back-link">&larr; Return to Headquarters</a>
    </div>

    <div class="form-card">
        <h2>Post a Video</h2>

        <% if (error) { %>
            <div class="form-error"><%= error %></div>
        <% } %>

        <form action="/videos" method="POST">
            <div class="form-group">
                <label for="title">Video Title</label>
                <input type="text" id="title" name="title" required autofocus placeholder="e.g. Les Paul Tone Test">
            </div>

            <div class="form-group">
                <label for="link">Link to Your Video</label>
                <input type="url" id="link" name="link" required placeholder="Direct .mp4 link or a YouTube link">
                <p class="form-hint">Paste a direct video file link (.mp4) to play it inline, or a YouTube link to embed it.</p>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" placeholder="What's in the video?"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Publish Video</button>
        </form>
    </div>

    <hr class="section-divider">

    <h2 class="page-header" style="margin-bottom:1.5rem;">Community Videos</h2>

    <% if (!videos || videos.length === 0) { %>
        <div class="empty-state">No videos posted yet. Be the first!</div>
    <% } else { %>
        <div class="listing-grid">
            <% videos.forEach(function(video) {
                var ytMatch = video.link.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([\w-]{6,})/);
                var isMp4 = /\.mp4(\?.*)?$/i.test(video.link);
            %>
                <div class="listing-card">
                    <h3><%= video.title %></h3>
                    <% if (video.description) { %>
                        <p><%= video.description %></p>
                    <% } %>
                    <% if (isMp4) { %>
                        <video controls src="<%= video.link %>"></video>
                    <% } else if (ytMatch) { %>
                        <iframe src="https://www.youtube.com/embed/<%= ytMatch[1] %>" allowfullscreen></iframe>
                    <% } else { %>
                        <a href="<%= video.link %>" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Watch &#8599;</a>
                    <% } %>
                    <div class="listing-meta">
                        <span>Posted by <strong><%= video.postedBy %></strong></span>
                        <span><%= new Date(video.createdAt).toLocaleDateString() %></span>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</main>


<%- include('partials/footer') %>
</body>
</html>
